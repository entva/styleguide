{
  "name": "stylelint-config-entva",
  "description": "Shareable entva styleguide config for stylelint",
  "author": "Max Degterev <max@degterev.me>",
  "license": "MIT",
  "readmeFilename": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/entva/styleguide.git"
  },
  "bugs": "https://github.com/entva/styleguide/issues",
  "version": "2.48.0",
  "keywords": [
    "linter",
    "config",
    "stylelint"
  ],
  "type": "module",
  "main": "index.js",
  "files": [
    "index.js"
  ],
  "scripts": {
    "reinstall": "rm -rf node_modules package-lock.json && npm install",
    "oxlint": "oxlint -c node_modules/@entva/oxlint-config/index.json --ignore-path node_modules/@entva/oxlint-config/ignore-patterns.txt",
    "test": "node ../../../test ./test css",
    "prepublishOnly": "npm test"
  },
  "devDependencies": {
    "@entva/oxlint-config": "^2.x.x",
    "oxlint": "^1.73.0",
    "stylelint": "^17.14.0"
  },
  "dependencies": {
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.2.0"
  },
  "peerDependencies": {
    "stylelint": "^17.x.x"
  }
}
