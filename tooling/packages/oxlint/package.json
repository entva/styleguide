{
  "name": "@entva/oxlint-config",
  "description": "Shareable entva styleguide config for oxlint",
  "author": "Max Degterev <max@degterev.me>",
  "license": "MIT",
  "readmeFilename": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/entva/styleguide.git"
  },
  "bugs": "https://github.com/entva/styleguide/issues",
  "version": "2.51.0",
  "keywords": [
    "linter",
    "config",
    "oxlint",
    "styleguide",
    "typescript",
    "react"
  ],
  "files": [
    "index.json",
    "storybook.json",
    "next.json",
    "next-storybook.json",
    "ignore-patterns.txt",
    "eslint-core-shim.js"
  ],
  "type": "module",
  "exports": {
    ".": "./index.json",
    "./storybook": "./storybook.json",
    "./next": "./next.json",
    "./next-storybook": "./next-storybook.json"
  },
  "scripts": {
    "reinstall": "rm -rf node_modules package-lock.json && npm install",
    "test": "node test/run.js",
    "rules": "oxlint -c index.json --print-config > oxlint-ruleset-output.json",
    "prepublishOnly": "npm test"
  },
  "devDependencies": {
    "eslint-plugin-storybook": "^10.5.3",
    "oxlint": "^1.75.0",
    "oxlint-tsgolint": "^7.0.2001",
    "react": "^19.2.8",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5"
  },
  "peerDependencies": {
    "eslint-plugin-storybook": "^10.x.x",
    "oxlint": "^1.x.x",
    "oxlint-tsgolint": "^0.x.x || ^7.x.x"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-storybook": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  }
}
